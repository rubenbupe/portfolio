---
import { cn } from '../lib/utils';

type Props = {
	number?: number;
};

const { number = 20 } = Astro.props;

const meteors = [...new Array(number)].map(() => {
	const animationDelay = Math.random() * 1 + 0.2 + 's';
	const animationDuration = Math.floor(Math.random() * 8 + 2) + 's';
	return {
		meteor: {
			top: '-5px',
			left: `calc(${Math.random()}*100vw)`,
			animationDelay: animationDelay,
			animationDuration: animationDuration
		},
		trail: {
			animationDelay: animationDelay,
			animationDuration: animationDuration
		}
	};
});
---

<>
	{
		[...meteors].map(style => (
			<span
				class={cn(
					'pointer-events-none absolute left-1/2 top-1/2 size-0.5 rotate-215 animate-meteor rounded-full bg-slate-500 shadow-[0_0_0_1px_#ffffff10]'
				)}
				style={style.meteor}
			>
				<div
					class="pointer-events-none absolute top-1/2 -z-1 h-px animate-meteor-trail -translate-y-1/2 bg-linear-to-r from-slate-500 to-transparent"
					style={style.trail}
				/>
			</span>
		))
	}
</>

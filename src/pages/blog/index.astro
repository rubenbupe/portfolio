---
import { getPosts, getFeaturedPosts } from '../../lib/fetchers';
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import BlogCard from '../../components/BlogCard.astro';
import { Particles } from '../../components/Particles';

const posts = await getPosts();
const featuredPosts = await getFeaturedPosts();
---

<Layout title="Blog">
	<Section class="py-24 flex flex-col gap-12">
		{
			featuredPosts.length > 0 && (
				<>
					<h1 class="text-4xl font-bold sm:text-5xl md:text-7xl pb-2 bg-linear-to-b from-20% dark:from-50% to-100% from-[#808080] to-black dark:from-white dark:to-gray-400 text-transparent bg-clip-text dark:[text-shadow:0_1px_5px_rgb(0_0_0/20%)] [text-shadow:0_0_4px_rgb(0_0_0/20%)]">
						Blog
					</h1>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-8 -mx-4">
						{featuredPosts.map(post => (
							<BlogCard {...post} />
						))}
					</div>
				</>
			)
		}
		{
			posts.length > 0 && (
				<>
					<h2 class="text-2xl font-medium pb-1 tracking-tight sm:text-3xl md:text-4xl bg-linear-to-b from-50% to-100% from-white to-gray-400 text-transparent bg-clip-text [text-shadow:0_1px_5px_rgb(0_0_0/20%)]">
						Other Posts
					</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 -mx-4 gap-y-8">
						{posts.map(post => (
							<BlogCard {...post} />
						))}
					</div>
				</>
			)
		}
	</Section>
	<div class="w-full max-w-160 h-40 relative self-center mask-[radial-gradient(at_bottom,white_20%,transparent)]">
		<Particles client:visible theme="auto" minSize={0.4} maxSize={1} particleDensity={100} className="w-full h-full" />
	</div>
</Layout>

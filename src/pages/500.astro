			class="text-3xl font-medium sm:text-4xl md:text-5xl pb-1 mt-3 bg-linear-to-b from-20% dark:from-50% to-100% from-[#808080] to-black dark:from-white dark:to-gray-400 text-transparent bg-clip-text dark:[text-shadow:0_1px_5px_rgb(0_0_0/20%)] [text-shadow:0_0_4px_rgb(0_0_0/30%)]"

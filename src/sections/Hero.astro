---
import Section from '../components/Section.astro';
import HeroAnimation from '../components/MeteorAnimation.astro';
import { Icon } from 'astro-icon/components';
import { githubUrl, mailUrl } from '../constants/site';
import Anchor from '../components/Anchor.astro';
---

<div class="relative w-full overflow-hidden flex flex-col">
	<HeroAnimation number={30} />
	<Section id="home" class="relative py-24 min-h-[80vh]">
		<h1
			class="text-4xl font-bold sm:text-5xl md:text-7xl bg-linear-to-b from-20% dark:from-50% to-100% from-[#808080] to-black dark:from-white dark:to-gray-400 text-transparent bg-clip-text dark:[text-shadow:0_1px_5px_rgb(0_0_0/20%)] [text-shadow:0_0_4px_rgb(0_0_0/20%)]"
		>
			Rubén Buzón
		</h1>
		<h2
			class="text-3xl font-bold tracking-tight sm:text-4xl md:text-6xl pb-3 mt-3 bg-linear-to-b from-20% dark:from-50% to-100% from-[#808080] to-black dark:from-white dark:to-gray-400 text-transparent bg-clip-text dark:[text-shadow:0_1px_5px_rgb(0_0_0/20%)] [text-shadow:0_0_4px_rgb(0_0_0/20%)]"
		>
			Full-Stack Engineer
		</h2>
		<p class="mt-4 max-w-lg leading-normal text-foreground/50 md:text-lg">
			I'm a Full-Stack engineer with a passion for building high-quality and scalable software. I have experience in
			both frontend and backend technologies, and I'm always looking for new challenges.
		</p>
		<div class="flex gap-4 mt-8">
			<Anchor size="default" href={mailUrl} target="_blank"> Get in touch </Anchor>
			<Anchor size="default" variant="outline" href={githubUrl} target="_blank">
				<Icon name="tabler:brand-github-filled" class="mr-2" />
				Github
			</Anchor>
		</div>
	</Section>
	<div class="absolute bottom-4 left-0 right-0 mx-auto flex justify-center">
		<Anchor href="#about" size="default" variant="outline" class="rounded-full p-2 animate-bounce !corner-round">
			<Icon name="tabler:arrow-down" size={18} />
			<span class="sr-only">Scroll down</span>
		</Anchor>
	</div>
</div>
